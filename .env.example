# ============================================================
# 群晖 NAS 管理 API 环境配置示例
# ============================================================
# 复制此文件为 .env 并填写实际配置值

# ============================================================
# DSM API 配置
# ============================================================
# NAS 的 IP 地址或主机名
DSM_HOST=192.168.1.10

# DSM API 端口（默认 HTTPS 为 5001，HTTP 为 5000）
DSM_PORT=5001

# NAS 登录用户名（需要有相应权限）
NAS_USER=admin

# NAS 登录密码
NAS_PASSWORD=your_password_here

# ============================================================
# API 认证配置
# ============================================================
# API 访问 Token（必需）
# 支持多个 Token，用逗号分隔
# 示例：TOKEN=token1,token2,token3
TOKEN=your_secret_token_here

# IP 白名单（可选）
# 允许访问的 IP 地址，用逗号分隔
# 留空则允许所有 IP（不推荐生产环境）
# 示例：ALLOW_IP=127.0.0.1,192.168.1.100,192.168.1.0/24
ALLOW_IP=

# ============================================================
# 应用配置（可选）
# ============================================================
# 应用名称
APP_NAME=群晖NAS管理API

# 调试模式（true/false）
DEBUG=false

# ============================================================
# 健康检查配置（可选）
# ============================================================
# 是否启用健康检查（true/false）
HEALTH_CHECK_ENABLED=true

# 健康检查超时时间（秒）
HEALTH_CHECK_TIMEOUT=5

# ============================================================
# Docker 部署说明
# ============================================================
# 1. 构建镜像：
#    docker build -t qunhuiinas:latest .
#
# 2. 启动服务：
#    docker-compose up -d
#
# 3. 查看健康状态：
#    docker ps
#    docker inspect --format='{{.State.Health.Status}} <container_id>'
#
# 4. 查看健康检查日志：
#    docker inspect --format='{{range .State.Health.Log}}{{.Output}}{{end}}' <container_id>
#
# 5. 心跳机制说明：
#    - Docker 每5分钟自动调用 /health 接口
#    - 这会保持 NAS 会话活跃，避免超时
#    - 连续3次失败才标记为不健康
#    - 可通过调整 interval 参数改变心跳频率

# ============================================================
# 注意事项
# ============================================================
# 1. 请勿将 .env 文件提交到版本控制系统
# 2. 生产环境请使用强密码作为 TOKEN
# 3. 建议定期更换 TOKEN
# 4. 配置 ALLOW_IP 限制访问来源
# 5. 心跳间隔建议设置为 NAS 会话超时时间的 1/3 到 1/2
